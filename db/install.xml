<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/timetable/db" VERSION="2026033100" COMMENT="XMLDB file for local_timetable"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd">
  <TABLES>
    <TABLE NAME="local_timetable_cache" COMMENT="Cached timetable payloads per user filter set">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="cachekey" TYPE="char" LENGTH="64" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="useremail" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="cohortkeys" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="responsejson" TYPE="text" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="versionsjson" TYPE="text" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="timefetched" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="cachekey_uix" UNIQUE="true" FIELDS="cachekey"/>
        <INDEX NAME="userid_ix" UNIQUE="false" FIELDS="userid"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
